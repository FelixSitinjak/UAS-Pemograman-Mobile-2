<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title=""
        tools:title="">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/toolbar_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="56dp"
            android:paddingEnd="56dp"
            android:text="Analisis Kalori Makanan Dan Minuman"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="12sp"
            app:autoSizeMaxTextSize="30sp"
            app:autoSizeStepGranularity="1sp"
            tools:text="Analisis Kalori Makanan Dan Minuman" />

    </com.google.android.material.appbar.MaterialToolbar>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <View
                android:id="@+id/step_line"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:background="@color/gray_200"
                app:layout_constraintBottom_toBottomOf="@id/step_2"
                app:layout_constraintEnd_toEndOf="@id/step_3"
                app:layout_constraintStart_toStartOf="@id/step_1"
                app:layout_constraintTop_toTopOf="@id/step_2" />

            <TextView
                android:id="@+id/step_1"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_circle_purple_1"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/step_2"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_gray_200"
                android:gravity="center"
                android:text="2"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/step_1" />

            <TextView
                android:id="@+id/step_3"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_gray_200"
                android:gravity="center"
                android:text="3"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/step_1" />

            <TextView
                android:id="@+id/step_1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Pilih Foto"
                android:textColor="@color/black"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="@id/step_1"
                app:layout_constraintTop_toBottomOf="@id/step_1" />

            <TextView
                android:id="@+id/step_2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Analisis"
                android:textColor="@color/black"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@id/step_2"
                app:layout_constraintStart_toStartOf="@id/step_2"
                app:layout_constraintTop_toBottomOf="@id/step_2" />

            <TextView
                android:id="@+id/step_3_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Simpan"
                android:textColor="@color/black"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="@id/step_3"
                app:layout_constraintTop_toBottomOf="@id/step_3" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_take_photo"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_round_purple_16"
                android:padding="18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/step_1_label">

                <FrameLayout
                    android:id="@+id/take_icon_container"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_circle_white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_24"
                        android:contentDescription="" />

                </FrameLayout>

                <TextView
                    android:id="@+id/take_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Ambil Foto Makanan"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/take_icon_container"
                    app:layout_constraintTop_toTopOf="@id/take_icon_container" />

                <TextView
                    android:id="@+id/take_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:text="Gunakan kamera untuk mengambil foto\natau pilih dari galeri anda"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/take_icon_container"
                    app:layout_constraintTop_toBottomOf="@id/take_title" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_preview"
                android:layout_width="0dp"
                android:layout_height="260dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_round_purple_16"
                android:padding="18dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_take_photo">

                <FrameLayout
                    android:id="@+id/preview_icon_container"
                    android:layout_width="74dp"
                    android:layout_height="74dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_circle_white"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_24"
                        android:contentDescription="" />
                </FrameLayout>

                <TextView
                    android:id="@+id/preview_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Foto Makanan Anda"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_icon_container" />

                <TextView
                    android:id="@+id/preview_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Ambil foto atau pilih dari galeri untuk\nmenganalisis nutrisi makanan secara otomatis"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/preview_title" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/action_take"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_round_gray_16"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_preview">

                <FrameLayout
                    android:id="@+id/action_take_icon_container"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_circle_white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_camera_24"
                        android:contentDescription="" />
                </FrameLayout>

                <TextView
                    android:id="@+id/action_take_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="Ambil Foto"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/action_take_chev"
                    app:layout_constraintStart_toEndOf="@id/action_take_icon_container"
                    app:layout_constraintTop_toTopOf="@id/action_take_icon_container" />

                <TextView
                    android:id="@+id/action_take_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="4dp"
                    android:text="Gunakan kamera untuk foto\nlangsung"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/action_take_chev"
                    app:layout_constraintStart_toEndOf="@id/action_take_icon_container"
                    app:layout_constraintTop_toBottomOf="@id/action_take_title" />

                <ImageView
                    android:id="@+id/action_take_chev"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right_24"
                    android:contentDescription=""
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/action_pick"
                android:layout_width="0dp"
                android:layout_height="76dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_round_gray_16"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/action_take">

                <FrameLayout
                    android:id="@+id/action_pick_icon_container"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_circle_white"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_image_24"
                        android:contentDescription="" />
                </FrameLayout>

                <TextView
                    android:id="@+id/action_pick_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:text="Pilih foto"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/action_pick_chev"
                    app:layout_constraintStart_toEndOf="@id/action_pick_icon_container"
                    app:layout_constraintTop_toTopOf="@id/action_pick_icon_container" />

                <TextView
                    android:id="@+id/action_pick_subtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_marginTop="4dp"
                    android:text="Pilih foto yang sudah ada"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/action_pick_chev"
                    app:layout_constraintStart_toEndOf="@id/action_pick_icon_container"
                    app:layout_constraintTop_toBottomOf="@id/action_pick_title" />

                <ImageView
                    android:id="@+id/action_pick_chev"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chevron_right_24"
                    android:contentDescription=""
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>